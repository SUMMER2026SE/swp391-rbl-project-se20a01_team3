@startuml UC01_Sequence_Diagram
title UC01 - Sơ đồ tuần tự - Đăng ký tài khoản bằng OTP

autonumber
skinparam defaultFontName Arial
skinparam shadowing false
skinparam responseMessageBelowArrow true
skinparam sequence {
  ArrowColor #30475E
  ActorBorderColor #30475E
  LifeLineBorderColor #7B8794
  LifeLineBackgroundColor #FFFFFF
  ParticipantBorderColor #30475E
  ParticipantBackgroundColor #F7F9FB
  GroupBorderColor #7B8794
  GroupBackgroundColor #F7F9FB
}

actor "Guest (Khách)" as Guest
boundary "Register.tsx" as Register
control "authService.ts" as FrontendAuthService
boundary "AuthController" as AuthController
control "AuthService" as AuthService
control "GlobalExceptionHandler" as ErrorHandler
database "ProfileRepository" as ProfileRepository
control "OtpService" as OtpService
collections "OTP store\nConcurrentHashMap" as OtpStore
participant "JavaMailSender" as MailSender
participant "SMTP / Gmail" as MailServer
control "SupabaseAuthClient\n(AuthProviderClient)" as SupabaseClient
participant "Supabase GoTrue\nAdmin API" as SupabaseAuth
entity "Profile" as Profile
database "Supabase PostgreSQL" as Database

group Bước 1 - Gửi OTP
  Guest -> Register : Nhập fullName, email, password, role\nvà chọn Đăng ký
  Register -> Register : validateForm()

  alt Dữ liệu frontend không hợp lệ
    Register --> Guest : Hiển thị thông báo validation
  else Dữ liệu frontend hợp lệ
    Register -> FrontendAuthService : requestOtp({email, fullName, role})
    FrontendAuthService -> AuthController : POST /api/auth/register/request-otp
    AuthController -> AuthController : @Valid RequestOtpRequest

    alt DTO backend không hợp lệ
      AuthController -> ErrorHandler : MethodArgumentNotValidException
      ErrorHandler --> FrontendAuthService : HTTP 400 VALIDATION_FAILED
      FrontendAuthService --> Register : Promise bi reject
      Register --> Guest : notify.error(...)
    else DTO backend hợp lệ
      AuthController -> AuthService : requestOtp(request)
      AuthService -> AuthService : UserRole.fromDbValue(role)\nva isAllowedForPublicSignup()

      alt Vai trò không được phép
        AuthService -> ErrorHandler : BusinessException(INVALID_ROLE)
        ErrorHandler --> FrontendAuthService : HTTP 400 ErrorResponse
        FrontendAuthService --> Register : Promise bi reject
        Register --> Guest : Hiển thị lỗi
      else Vai trò hợp lệ
        AuthService -> ProfileRepository : existsByEmailInAuth(email)
        ProfileRepository -> Database : SELECT EXISTS FROM auth.users\nWHERE LOWER(email) = LOWER(:email)
        Database --> ProfileRepository : true / false
        ProfileRepository --> AuthService : exists

        alt Email đã tồn tại
          AuthService -> ErrorHandler : BusinessException(EMAIL_ALREADY_EXISTS)
          ErrorHandler --> FrontendAuthService : HTTP 409 ErrorResponse
          FrontendAuthService --> Register : Promise bi reject
          Register --> Guest : "Email này đã được đăng ký"
        else Email chưa tồn tại
          AuthService -> OtpService : send(email, fullName, role)
          OtpService -> OtpService : generateCode()\n6 chữ số ngẫu nhiên
          OtpService -> OtpStore : put(lowercase(email),\nOtpEntry(..., expiresAt = now + 300s))
          OtpService -> MailSender : send(HTML email chứa OTP)
          MailSender -> MailServer : Gửi email SMTP
          MailServer --> Guest : Nhận mã OTP

          note right of OtpService
            Nếu gửi mail lỗi và devMode=true,
            hệ thống ghi OTP vào log và vẫn tiếp tục.
            Nếu devMode=false, trả MAIL_SEND_FAILED.
          end note

          OtpService --> AuthService : void
          AuthService --> AuthController : void
          AuthController --> FrontendAuthService : HTTP 200 ApiResponse
          FrontendAuthService --> Register : resolved
          Register -> Register : setStep(2)\nstartResendCooldown(60s)
          Register --> Guest : Hiển thị màn hình nhập OTP
        end
      end
    end
  end
end

group Bước 2 - Xác minh OTP và tạo tài khoản
  Guest -> Register : Nhập 6 chữ số OTP\nvà chọn Xác nhận & Tạo tài khoản
  Register -> Register : otp.join("") và kiểm tra đủ 6 số

  alt OTP chưa đủ 6 số
    Register --> Guest : "Vui lòng nhập đủ 6 chữ số"
  else OTP đủ 6 số
    Register -> FrontendAuthService : verifyOtp({email, otp, password})
    FrontendAuthService -> AuthController : POST /api/auth/register/verify-otp
    AuthController -> AuthController : @Valid VerifyOtpRequest

    alt DTO backend không hợp lệ
      AuthController -> ErrorHandler : MethodArgumentNotValidException
      ErrorHandler --> FrontendAuthService : HTTP 400 VALIDATION_FAILED
      FrontendAuthService --> Register : Promise bi reject
      Register --> Guest : notify.error(...)
    else DTO backend hợp lệ
      AuthController -> AuthService : verifyOtpAndRegister(request)
      AuthService -> OtpService : verify(email, otp)
      OtpService -> OtpStore : get(lowercase(email))
      OtpStore --> OtpService : OtpEntry / null

      alt Không tìm thấy OTP
        OtpService -> ErrorHandler : BusinessException(OTP_NOT_FOUND)
        ErrorHandler --> FrontendAuthService : HTTP 400 ErrorResponse
        FrontendAuthService --> Register : Promise bi reject
        Register --> Guest : Hiển thị lỗi
      else OTP đã hết hạn
        OtpService -> OtpStore : remove(lowercase(email))
        OtpService -> ErrorHandler : BusinessException(OTP_EXPIRED)
        ErrorHandler --> FrontendAuthService : HTTP 400 ErrorResponse
        FrontendAuthService --> Register : Promise bi reject
        Register --> Guest : Yêu cầu gửi lại OTP
      else OTP không đúng
        OtpService -> ErrorHandler : BusinessException(OTP_INVALID)
        ErrorHandler --> FrontendAuthService : HTTP 400 ErrorResponse
        FrontendAuthService --> Register : Promise bi reject
        Register --> Guest : Hiển thị lỗi, cho phép thử lại
      else OTP hợp lệ
        OtpService --> AuthService : OtpEntry(fullName, role, expiresAt)
        AuthService -> AuthService : Tạo metadata {role, full_name}
        AuthService -> SupabaseClient : signUp(email, password, metadata)
        SupabaseClient -> SupabaseAuth : POST /auth/v1/admin/users\nemail_confirm=true + service_role_key

        alt Supabase Auth tạo user thất bại
          SupabaseAuth --> SupabaseClient : HTTP 4xx / 5xx
          SupabaseClient --> AuthService : BusinessException
          AuthService -> ErrorHandler : Propagate exception
          ErrorHandler --> FrontendAuthService : HTTP 4xx / 502 ErrorResponse
          FrontendAuthService --> Register : Promise bi reject
          Register --> Guest : Hiển thị lỗi
          note right of OtpStore
            OTP chưa bị consume,
            nên người dùng có thể thử lại.
          end note
        else Auth user được tạo
          SupabaseAuth --> SupabaseClient : ProviderUser(id, email, metadata)
          SupabaseClient --> AuthService : ProviderUser
          AuthService -> Profile : createNew(id, role, fullName)

          opt Vai trò là TEACHER
            AuthService -> Profile : markTeacherPendingApproval()
          end

          AuthService -> ProfileRepository : save(profile)
          ProfileRepository -> Database : INSERT INTO public.profiles

          alt Lưu profile thất bại
            Database --> ProfileRepository : Persistence exception
            ProfileRepository --> AuthService : Exception
            AuthService -> ErrorHandler : Transaction rollback
            ErrorHandler --> FrontendAuthService : HTTP 500 ErrorResponse
            FrontendAuthService --> Register : Promise bi reject
            Register --> Guest : Hiển thị lỗi hệ thống
            note right of SupabaseAuth
              Transaction chỉ rollback database local.
              Auth user bên Supabase đã tạo không tự rollback;
              đây là rủi ro saga đã được ghi chú trong AuthService.
            end note
          else Lưu profile thành công
            Database --> ProfileRepository : Profile đã lưu
            ProfileRepository --> AuthService : Profile
            AuthService -> OtpService : consume(email)
            OtpService -> OtpStore : remove(lowercase(email))
            AuthService -> AuthService : UserSummaryResponse.fromProfile(...)
            AuthService --> AuthController : UserSummaryResponse
            AuthController --> FrontendAuthService : HTTP 200 ApiResponse\n"Tạo tài khoản thành công"
            FrontendAuthService --> Register : UserSummary
            Register -> Register : setStep(3)
            Register --> Guest : Hiển thị đăng ký thành công
            Register -> Register : Sau 4 giây: navigate("/login")
          end
        end
      end
    end
  end
end

opt Người dùng chọn Gửi lại sau cooldown
  Guest -> Register : Chọn Gửi lại mã
  Register -> FrontendAuthService : requestOtp({email, fullName, role})
  note right of OtpStore
    Cùng luồng Bước 1; entry mới ghi đè entry cũ
    và thời hạn 5 phút được tính lại.
  end note
end

note over Register, AuthController
  Sơ đồ bám theo luồng OTP mà Register.tsx đang sử dụng.
  Endpoint đăng ký trực tiếp POST /api/auth/register không nằm trong luồng này.
end note

@enduml
