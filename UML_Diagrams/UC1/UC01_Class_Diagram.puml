@startuml UC01_Class_Diagram
title UC01 - Sơ đồ lớp - Đăng ký tài khoản bằng OTP

left to right direction
hide circle
hide empty members
skinparam defaultFontName Arial
skinparam classAttributeIconSize 0
skinparam linetype ortho
skinparam packageStyle rectangle
skinparam shadowing false

package "Giao diện - React" #EEF6FF {
  class "Register.tsx" as Register <<boundary>> {
    - step: Step
    - fullName: string
    - email: string
    - password: string
    - role: Role
    - otp: string[6]
    - submitting: boolean
    - resendCooldown: number
    --
    - validateForm(): string | null
    + handleRequestOtp(): Promise~void~
    + handleVerifyOtp(): Promise~void~
    + handleResend(): Promise~void~
  }

  class "authService.ts" as FrontendAuthService <<service>> {
    + requestOtp(payload: RequestOtpPayload): Promise~void~
    + verifyOtp(payload: VerifyOtpPayload): Promise~UserSummary~
  }

  class RequestOtpPayload <<DTO>> {
    + email: string
    + fullName: string
    + role: student | parent | teacher
  }

  class VerifyOtpPayload <<DTO>> {
    + email: string
    + otp: string
    + password: string
  }
}

package "Backend - Spring Boot" #F7F7F7 {
  package "Tầng API" {
    class AuthController <<controller>> {
      - authService: AuthService
      --
      + requestOtp(request: RequestOtpRequest): ApiResponse~Void~
      + verifyOtp(request: VerifyOtpRequest): ApiResponse~UserSummaryResponse~
    }

    class GlobalExceptionHandler <<advice>> {
      + handleBusinessException(ex): ErrorResponse
      + handleValidation(ex): ErrorResponse
    }

    class RequestOtpRequest <<record>> {
      + email: String
      + fullName: String
      + role: String
    }

    class VerifyOtpRequest <<record>> {
      + email: String
      + otp: String
      + password: String
    }

    class UserSummaryResponse <<record>> {
      + id: UUID
      + email: String
      + role: String
      + fullName: String
      + avatarUrl: String
      --
      {static} + fromProfile(profile, email): UserSummaryResponse
    }
  }

  package "Tầng nghiệp vụ" {
    class AuthService <<service>> {
      - authProviderClient: AuthProviderClient
      - profileRepository: ProfileRepository
      - otpService: OtpService
      --
      + requestOtp(request: RequestOtpRequest): void
      + verifyOtpAndRegister(request: VerifyOtpRequest): UserSummaryResponse
    }

    class OtpService <<service>> {
      {static} - OTP_TTL_SECONDS: int = 300
      {static} - OTP_LENGTH: int = 6
      - store: ConcurrentHashMap~String, OtpEntry~
      - random: SecureRandom
      - devMode: boolean
      --
      + send(email, fullName, role): void
      + verify(email, otpCode): OtpEntry
      + consume(email): void
      - generateCode(): String
      - sendEmail(to, fullName, code): void
    }

    class OtpEntry <<record>> {
      + fullName: String
      + role: String
      + otpCode: String
      + expiresAt: Instant
    }
  }

  package "Tích hợp và lưu trữ" {
    interface AuthProviderClient <<port>> {
      + signUp(email, password, metadata): ProviderUser
    }

    class SupabaseAuthClient <<adapter>> {
      - restClient: RestClient
      - anonKey: String
      - serviceRoleKey: String
      --
      + signUp(email, password, metadata): ProviderUser
    }

    interface ProfileRepository <<repository>> {
      + existsByEmailInAuth(email): boolean
      + save(profile): Profile
    }

    interface JavaMailSender <<framework>> {
      + send(message): void
    }

    class ProviderUser <<record>> {
      + id: UUID
      + email: String
      + emailConfirmedAt: String
      + userMetadata: Map
      + appMetadata: Map
    }
  }

  package "Miền nghiệp vụ" {
    class Profile <<entity>> {
      - id: UUID
      - role: UserRole
      - fullName: String
      - avatarUrl: String
      - teacherApprovalStatus: String
      - createdAt: Instant
      - updatedAt: Instant
      --
      {static} + createNew(authUserId, role, fullName): Profile
      + markTeacherPendingApproval(): void
    }

    enum UserRole {
      STUDENT
      PARENT
      TEACHER
      ADMIN
      --
      + toDbValue(): String
      {static} + fromDbValue(value): UserRole
      + isAllowedForPublicSignup(): boolean
    }
  }
}

cloud "Máy chủ SMTP / Gmail" as SmtpServer
database "Supabase Auth\nauth.users" as AuthUsers
database "Supabase PostgreSQL\npublic.profiles" as ProfilesDb

Register --> FrontendAuthService : gọi
FrontendAuthService ..> RequestOtpPayload
FrontendAuthService ..> VerifyOtpPayload
FrontendAuthService ..> AuthController : gửi HTTP JSON

AuthController --> AuthService
AuthController ..> RequestOtpRequest
AuthController ..> VerifyOtpRequest
AuthController ..> UserSummaryResponse
AuthController ..> GlobalExceptionHandler : Spring ánh xạ exception

AuthService --> OtpService
AuthService --> AuthProviderClient
AuthService --> ProfileRepository
AuthService ..> Profile : createNew()
AuthService ..> UserRole : kiểm tra vai trò
AuthService ..> UserSummaryResponse : trả về

OtpService *-- OtpEntry
OtpService --> JavaMailSender
JavaMailSender --> SmtpServer : gửi email OTP

SupabaseAuthClient ..|> AuthProviderClient
AuthProviderClient ..> ProviderUser : trả về
SupabaseAuthClient --> AuthUsers : POST /auth/v1/admin/users

ProfileRepository ..> Profile
ProfileRepository --> AuthUsers : SELECT EXISTS theo email
ProfileRepository --> ProfilesDb : INSERT profile
Profile --> UserRole
UserSummaryResponse ..> Profile : ánh xạ từ

note bottom of Register
  Màn hình Register hiện tại sử dụng luồng OTP hai bước.
  Endpoint POST /api/auth/register vẫn tồn tại trong backend,
  nhưng không được màn hình này gọi.
end note

note right of OtpService
  Mỗi email có một OTP đang chờ.
  OTP gồm 6 chữ số, có hiệu lực 5 phút
  và chỉ bị xóa sau khi tạo tài khoản thành công.
end note

note bottom of Profile
  Profile dùng chung UUID với auth.users.
  Tài khoản TEACHER mới được đánh dấu PENDING.
end note

@enduml
